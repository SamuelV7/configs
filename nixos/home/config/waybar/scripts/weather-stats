#!/usr/bin/env bash
set -euo pipefail

location="${WAYBAR_WEATHER_LOCATION:-London}"

weather="$(curl -fsS --max-time 5 "https://wttr.in/${location}?format=%c+%t" 2>/dev/null || true)"

if [[ -z "$weather" ]]; then
  printf '{"text":"󰖐 N/A","tooltip":"Weather unavailable"}\n'
else
  printf '{"text":"%s","tooltip":"%s"}\n' "$weather" "wttr.in/${location}"
fi
