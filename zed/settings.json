// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "diff_view_style": "split",
  "which_key": {
    "enabled": true
  },
  "agent_servers": {
    
  },
  "disable_ai": false,
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "debugger": {
    "dock": "right"
  },
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "agent": {
    "default_profile": "write",
    "default_model": {
      "provider": "openai-subscribed",
      "model": "gpt-5.6-sol",
      "enable_thinking": true,
      "effort": "xhigh"
    },
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "title_bar":{
    "show_sign_in": false,
  },
  "diagnostics":{
    "inline": {
      "enabled": true,
      "max_severity":null
    }
  },
  "git_panel": {
    "dock": "left"
  },
  "vim_mode": true,
  "theme": "Gruvbox Dark Hard",
  "ui_font_size": 16,
  "buffer_font_size": 16
}
